[mysqld]
# ── Audit et logs MySQL ───────────────────────────────────────
general_log          = 1
general_log_file     = /var/log/mysql/general.log
slow_query_log       = 1
slow_query_log_file  = /var/log/mysql/slow.log
long_query_time      = 2

# ── Sécurité ─────────────────────────────────────────────────
local_infile         = 0
symbolic_links       = 0
skip_show_database

# ── Connexions ────────────────────────────────────────────────
max_connections      = 50
connect_timeout      = 10
wait_timeout         = 300
